# Prevent Directory Listing (Force Browsing Protection)
Options -Indexes

<IfModule mod_headers.c>
    # Mitigate Cross-Site Scripting (XSS)
    Header set X-XSS-Protection "1; mode=block"

    # Block MIME type sniffing strictly
    Header set X-Content-Type-Options "nosniff"

    # Block Clickjacking by disallowing embedding on external domains
    Header set X-Frame-Options "SAMEORIGIN"

    # Content Security Policy - COMPLETE (allows InfinityFree error pages)
    Header set Content-Security-Policy "default-src 'self' https://errors.infinityfree.net; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://errors.infinityfree.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com https://errors.infinityfree.net; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://errors.infinityfree.net; object-src 'none'"
</IfModule>

# Block sensitive internal codebase assets (.md logs, schemas, powershell scripts)
<FilesMatch "\.(md|sql|ps1|ini|env|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# The manifest requires an exception if you block `.json` broadly, but I haven't blocked `.json` here to prevent breaking frontend fetching logic (since JSON arrays populate the UI stats).